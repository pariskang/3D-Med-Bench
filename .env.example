# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-...

# Pulse Engine (optional, falls back to scripted mode if absent)
PULSE_SDK_PATH=/opt/pulse/sdk

# Godot 4 headless binary (optional, Tier A rendering)
GODOT_BIN=/usr/local/bin/godot4

# UMLS REST API (for SNOMED-CT lookups)
UMLS_API_KEY=

# MLflow tracking (optional)
MLFLOW_TRACKING_URI=sqlite:///clinicraft.db

# Pipeline settings
CLINICRAFT_CASES_DIR=./cases
CLINICRAFT_RESOURCES_DIR=./resources
CLINICRAFT_LOG_LEVEL=INFO
CLINICRAFT_LLM_MODEL=claude-opus-4-8
CLINICRAFT_JUDGE_MODEL=claude-opus-4-8
CLINICRAFT_BATCH_SIZE=10
CLINICRAFT_MAX_CONCURRENT=5
